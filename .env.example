GODRIVE_ADDR=127.0.0.1:8121
GODRIVE_DATA_ROOT=./var/data
GODRIVE_APPDATA_DIR=./var/appdata
GODRIVE_DB_PATH=./var/appdata/godrive.sqlite
GODRIVE_BOOTSTRAP_ADMIN_USER=admin
GODRIVE_BOOTSTRAP_ADMIN_PASSWORD=change-me
GODRIVE_BOOTSTRAP_ADMIN_ROOT=./var/data/admin
GODRIVE_COOKIE_SECURE=false
GODRIVE_COOKIE_SAMESITE=strict
GODRIVE_HSTS=false
GODRIVE_SESSION_TTL=720h
GODRIVE_ENABLE_WATCHER=true
GODRIVE_RECONCILE_INTERVAL=24h
GODRIVE_UPLOAD_TTL=48h
GODRIVE_PREVIEW_WORKERS=0
GODRIVE_PREVIEW_TIMEOUT=45s
GODRIVE_WEBHOOK_WORKERS=4
GODRIVE_WEBHOOK_ALLOW_HTTP=false
GODRIVE_WEBHOOK_ALLOW_PRIVATE=false
GODRIVE_DEV_LATENCY=10ms-25ms
